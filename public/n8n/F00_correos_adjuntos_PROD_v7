        "jsCode": "// INYECTAR IDs - version definitiva\n// messageId: del @odata.context (siempre en respuesta Graph)\n// correoId: GET a Supabase garantizado\n\nconst SB_URL = 'https://lyosqaqhiwhgvjigvqtc.supabase.co/rest/v1';\nconst SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imx5b3NxYXFoaXdoZ3ZqaWd2cXRjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4NDAxMjUsImV4cCI6MjA4OTQxNjEyNX0.DAaYGxf-Hbb9VW4J71_cu9w0ZD0iqTO0jHi5DT5__yg';\n\nconst respGraph = $input.first().json;\nconst todosAdjuntos = respGraph.value || [];\nif (!todosAdjuntos.length) return [];\n\n// PASO 1: extraer messageId del @odata.context de la respuesta de Graph\nlet messageId = '';\nconst ctx = respGraph['@odata.context'] || '';\nconst ctxMatch = ctx.match(/messages\\('([^']+)'\\)/);\nif (ctxMatch) messageId = decodeURIComponent(ctxMatch[1]);\n\n// PASO 2: intento rapido desde nodo anterior\nlet correoId = '';\ntry {\n  const c = $('¿Tiene Adjuntos?').item.json;\n  if (c.id) correoId = c.id;\n  if (!messageId && c.message_id) messageId = c.message_id;\n} catch(e) {}\n\n// PASO 3: GET a Supabase - garantizado\nif (!correoId && messageId) {\n  try {\n    const rows = await this.helpers.request({\n      method: 'GET',\n      url: SB_URL + '/correos?message_id=eq.' + messageId + '&select=id&limit=1',\n      headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + SB_KEY },\n      json: true\n    });\n    if (Array.isArray(rows) && rows[0]) correoId = rows[0].id || '';\n  } catch(e) {}\n}\n\nif (!correoId) {\n  throw new Error('Sin correo_id para messageId:' + messageId);\n}\n\n// Filtrar firmas inline y tracking pixels\nconst adjuntos = todosAdjuntos.filter(adj => {\n  const esInline = adj.isInline === true;\n  const esImagen = (adj.contentType || '').toLowerCase().startsWith('image/');\n  if (esInline && esImagen) return false;\n  if (esImagen && (adj.size || 0) < 5000) return false;\n  return true;\n});\n\nif (!adjuntos.length) return [];\n\nreturn adjuntos.map(adj => ({\n  json: { ...adj, _message_id: messageId, _correo_id: correoId }\n}));"
      },
