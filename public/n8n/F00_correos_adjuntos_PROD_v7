        "jsCode": "// Convierte base64 → binario para subir a Supabase Storage\nconst items = [];\n\nfor (const item of $input.all()) {\n  const base64      = item.json.contentBytes || '';\n  const nombre      = (item.json.name || 'adjunto').replace(/[^a-zA-Z0-9._\\-]/g, '_');\n  const contentType = item.json.contentType  || 'application/octet-stream';\n  const attachId    = item.json.id           || '';\n  const size        = item.json.size         || 0;\n  const isInline    = item.json.isInline     || false;\n\n  // Obtener message_id — viene inyectado como _message_id\n  // Lo sanitizamos: quitamos chars inválidos y limitamos longitud\n  const rawMsgId  = item.json._message_id || item.json.message_id || 'sin-id';\n  const messageId = rawMsgId\n    .replace(/[^a-zA-Z0-9\\-_]/g, '')\n    .substring(0, 80);\n\n  const correoId  = item.json._correo_id || item.json.correo_id || '';\n\n  // Nombre sanitizado para storage\n  const nombreSafe    = nombre;\n  const storagePath   = `${messageId}/${nombreSafe}`;\n  const storageUrl    = `https://lyosqaqhihwgvjigvqtc.supabase.co/storage/v1/object/public/adjuntos-pqr/${storagePath}`;\n\n  if (!base64) {\n    items.push({\n      json: {\n        attachment_id: attachId,\n        nombre: nombreSafe,\n        contentType,\n        size,\n        isInline,\n        message_id:   rawMsgId,\n        correo_id:    correoId,\n        storage_path: storagePath,\n        storage_url:  storageUrl,\n        sin_contenido: true\n      }\n    });\n    continue;\n  }\n\n  const buffer     = Buffer.from(base64, 'base64');\n  const binaryData = await this.helpers.prepareBinaryData(buffer, nombreSafe, contentType);\n\n  items.push({\n    json: {\n      attachment_id: attachId,\n      nombre:        nombreSafe,\n      contentType,\n      size,\n      isInline,\n      message_id:   rawMsgId,\n      correo_id:    correoId,\n      storage_path: storagePath,\n      storage_url:  storageUrl,\n      sin_contenido: false\n    },\n    binary: { data: binaryData }\n  });\n}\n\nreturn items;"
      },
