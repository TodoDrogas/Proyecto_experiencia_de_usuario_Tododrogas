    {
      "id": "afb3b3f6-0bcd-4fe3-9db8-51f65e7612af",
      "name": "Generar Ticket ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        200
      ],
      "parameters": {
        "jsCode": "// Generar ticket ID único TD-YYYYMMDD-XXXX\nconst now = new Date();\nconst pad = (n,l=2) => String(n).padStart(l,'0');\nconst fecha = now.getFullYear() + pad(now.getMonth()+1) + pad(now.getDate());\nconst rand = Math.floor(Math.random()*9000)+1000;\nconst ticket_id = `TD-${fecha}-${rand}`;\n\nconst body = $input.first().json.body || $input.first().json;\n\nreturn [{json: {\n  ticket_id,\n  nombre:       body.nombre        || body.name       || '',\n  correo:       body.correo        || body.email       || '',\n  telefono:     body.telefono      || body.phone       || '',\n  descripcion:  body.descripcion   || body.description || '',\n  tipo_pqr:     body.tipo_pqr      || body.tipo        || 'peticion',\n  origen:       body.origen        || 'web',\n  canal_contacto: body.canal       || 'formulario_web',\n  audio_url:    body.audio_url     || null,\n  canvas_url:   body.canvas_url    || null,\n  transcripcion: body.transcripcion || null,\n  subject:      `[${ticket_id}] PQR - ${body.nombre || 'Ciudadano'}`,\n  estado:       'pendiente',\n  prioridad:    'media',\n  received_at:  now.toISOString(),\n  created_at:   now.toISOString(),\n  updated_at:   now.toISOString()\n}}];"
      }
    },
    {
      "id": "e4a7d078-204e-4b65-8df1-7641cf887f06",
      "name": "INSERT PQR en Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        480,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "https://lyosqaqhihwgvjigvqtc.supabase.co/rest/v1/correos",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.SB_SERVICE_KEY }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.SB_SERVICE_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates,return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "retry": {
            "enabled": true,
            "maxTries": 3,
            "waitBetweenTries": 2000
          }
        }
      }
    },
    {
      "id": "11e38bbd-84ed-438f-8757-deae13cea116",
      "name": "Responder al Formulario",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        720,
