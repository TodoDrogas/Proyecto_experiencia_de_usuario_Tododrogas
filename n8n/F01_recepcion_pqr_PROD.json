        "responseBody": "={\"ok\":true,\"ticket_id\":\"{{ $('Generar Ticket ID').first().json.ticket_id }}\",\"mensaje\":\"Tu solicitud fue recibida. Ticket: {{ $('Generar Ticket ID').first().json.ticket_id }}\"}",
        "options": {
          "responseCode": 200
        }
      }
    },
